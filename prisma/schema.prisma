generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                 String              @id @default(uuid())
  name               String
  createdAt          DateTime            @default(now())
  groups             Group[]
  users              User[]
  trucks             Truck[]
  trips              Trip[]
  logo            String?
  logoPublicId  String?
  accountingEmail String?
  hrEmail         String?
  directorEmail   String?
  inviteToken  String?   @unique
  inviteExpiry DateTime?
  isActive     Boolean   @default(true)
  announcements      Announcement[]
  announcementDrafts AnnouncementDraft[]
  advanceRequests AdvanceRequest[]
}

model TruckNote {
  id        String   @id @default(uuid())
  truckId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  truck Truck @relation(fields: [truckId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

model User {
  id                 String              @id @default(uuid())
  name               String?
  email              String?             @unique
  phone              String?             @unique
  password           String?
  avatar String?
  avatarPublicId String? 
  role               Role
  language           Language            @default(EN)
  isActive           Boolean             @default(true)
  companyId          String
  createdAt          DateTime            @default(now())
  dispatcherId String?
  teamleadId   String?
  inviteToken    String?   
  inviteExpiry   DateTime?
  sentMessages     DirectMessage[] @relation("SentMessages")
  receivedMessages DirectMessage[] @relation("ReceivedMessages")
  groupMessages GroupMessage[]
  
  dispatcher User?  @relation("DriverDispatcher", fields: [dispatcherId], references: [id])
  teamlead   User?  @relation("DispatcherTeamlead", fields: [teamleadId], references: [id])
  drivers     User[] @relation("DriverDispatcher")
  dispatchers User[] @relation("DispatcherTeamlead")
  groupsCreated      Group[]             @relation("GroupCreator")
  groupDispatchers   GroupDispatcher[]
  truckNotes         TruckNote[]
  company            Company             @relation(fields: [companyId], references: [id])
  tripsAsDriver      Trip[]              @relation("DriverTrips")
  tripsAsDispatcher  Trip[]              @relation("DispatcherTrips")
  messages           Message[]
  comments           TripComment[]
  alarmsSent         Alarm[]             @relation("AlarmDispatcher")
  alarmsReceived     Alarm[]             @relation("AlarmDriver")
  uploadedDocuments  TripDocument[]
  announcementReads  AnnouncementRead[]
  announcements      Announcement[]
  announcementDrafts AnnouncementDraft[]
  currentTruck       Truck?              @relation("CurrentDriver")
  advanceRequests AdvanceRequest[] @relation("DriverAdvanceRequests")
  otpCodes           OtpCode[]
  ratingsReceived    DriverRating[] @relation("DriverRatings")
  ratingsGiven       DriverRating[] @relation("GivenRatings")
}

enum Role {
  ADMIN
  TEAMLEAD
  DISPATCHER
  DRIVER
}

enum Language {
  UK
  EN
  PL
  LT
  UZ
  KZ
  HI
  RU
}

model Truck {
  id              String      @id @default(uuid())
  plate           String
  status          TruckStatus @default(AVAILABLE)
  isActive        Boolean     @default(true)
  truckNotes      TruckNote[]
  companyId       String
  currentDriverId String?     @unique
  createdAt       DateTime    @default(now())

  groups        GroupTruck[]
  company       Company      @relation(fields: [companyId], references: [id])
  currentDriver User?        @relation("CurrentDriver", fields: [currentDriverId], references: [id])
  trips         Trip[]
}

enum TruckStatus {
  AVAILABLE
  ON_TRIP
  REPAIR
}

model Trip {
  id           String     @id @default(uuid())
  title        String
  status       TripStatus @default(ASSIGNED)
  dispatcherId String
  driverId     String
  truckId      String
  companyId    String
  createdAt    DateTime   @default(now())

  dispatcher User           @relation("DispatcherTrips", fields: [dispatcherId], references: [id])
  driver     User           @relation("DriverTrips", fields: [driverId], references: [id])
  truck      Truck          @relation(fields: [truckId], references: [id])
  company    Company        @relation(fields: [companyId], references: [id])
  documents  TripDocument[]
  messages   Message[]
  comments   TripComment[]
  alarms     Alarm[]
}

enum TripStatus {
  ASSIGNED
  ACCEPTED
  ON_WAY
  ON_SITE
  LOADED
  DELIVERED
}

model TripDocument {
  id         String   @id @default(uuid())
  tripId     String
  fileUrl    String
  fileName   String
  uploadedBy String
  createdAt  DateTime @default(now())
  publicId   String?
  trip     Trip @relation(fields: [tripId], references: [id])
  uploader User @relation(fields: [uploadedBy], references: [id])
}

model DirectMessage {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  isRead     Boolean  @default(false) 
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model Message {
  id                String   @id @default(uuid())
  tripId            String
  senderId          String
  content           String
  translatedContent String?
  createdAt         DateTime @default(now())

  trip   Trip @relation(fields: [tripId], references: [id])
  sender User @relation(fields: [senderId], references: [id])
}

model TripComment {
  id        String   @id @default(uuid())
  tripId    String
  driverId  String
  content   String
  createdAt DateTime @default(now())

  trip   Trip @relation(fields: [tripId], references: [id])
  driver User @relation(fields: [driverId], references: [id])
}

model Alarm {
  id           String   @id @default(uuid())
  tripId       String
  driverId     String
  dispatcherId String
  time         DateTime
  note         String?
  createdAt    DateTime @default(now())
  isSent       Boolean  @default(false)

  trip       Trip @relation(fields: [tripId], references: [id])
  driver     User @relation("AlarmDriver", fields: [driverId], references: [id])
  dispatcher User @relation("AlarmDispatcher", fields: [dispatcherId], references: [id])
}

model Announcement {
  id         String             @id @default(uuid())
  companyId  String
  createdBy  String
  title      String
  content    String
  target     AnnouncementTarget
  isTemplate Boolean            @default(false)
  createdAt  DateTime           @default(now())
  groupId    String?
  updatedAt DateTime @updatedAt

  group   Group?             @relation(fields: [groupId], references: [id])
  company Company            @relation(fields: [companyId], references: [id])
  creator User               @relation(fields: [createdBy], references: [id])
  reads   AnnouncementRead[]
}

enum AnnouncementTarget {
  ALL_DRIVERS
  ALL_DISPATCHERS
  ALL
}

model AnnouncementRead {
  id             String   @id @default(uuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
}

model AnnouncementDraft {
  id         String             @id @default(uuid())
  companyId  String
  createdBy  String
  title      String
  content    String
  target     AnnouncementTarget
  isTemplate Boolean            @default(false)
  createdAt  DateTime           @default(now())
  groupId    String?

  company Company @relation(fields: [companyId], references: [id])
  creator User    @relation(fields: [createdBy], references: [id])
  Group   Group?  @relation(fields: [groupId], references: [id])
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum GroupType {
  TRUCKS
  DISPATCHERS
}

model Group {
  id        String    @id @default(uuid())
  name      String
  type      GroupType
  companyId String
  createdBy String
  createdAt DateTime  @default(now())
  messages GroupMessage[]
  company            Company             @relation(fields: [companyId], references: [id])
  creator            User                @relation("GroupCreator", fields: [createdBy], references: [id])
  trucks             GroupTruck[]
  dispatchers        GroupDispatcher[]
  announcements      Announcement[]
  announcementsDraft AnnouncementDraft[]
}
model GroupMessage {
  id        String   @id @default(uuid())
  groupId   String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  group  Group @relation(fields: [groupId], references: [id])
  sender User  @relation(fields: [senderId], references: [id])
}

model GroupTruck {
  id      String @id @default(uuid())
  groupId String
  truckId String

  group Group @relation(fields: [groupId], references: [id])
  truck Truck @relation(fields: [truckId], references: [id])
}

model GroupDispatcher {
  id           String @id @default(uuid())
  groupId      String
  dispatcherId String

  group      Group @relation(fields: [groupId], references: [id])
  dispatcher User  @relation(fields: [dispatcherId], references: [id])
}
model DriverRating {
  id        String   @id @default(uuid())
  driverId  String
  ratedById String
  score     Int
  comment   String?
  createdAt DateTime @default(now())

  driver  User @relation("DriverRatings", fields: [driverId], references: [id])
  ratedBy User @relation("GivenRatings", fields: [ratedById], references: [id])

  @@unique([driverId, ratedById])
}

model AdvanceRequest {
  id        String        @id @default(uuid())
  driverId  String
  companyId String
  amount    Float
  reason    String
  createdAt DateTime      @default(now())

  driver  User    @relation("DriverAdvanceRequests", fields: [driverId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
}

