generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // DIRECT_URL — session-mode (port 5432) for Prisma migrations.
  // DATABASE_URL goes through pgbouncer (port 6543) for runtime queries.
  directUrl = env("DIRECT_URL")
}

model Company {
  id                 String              @id @default(uuid())
  name               String
  createdAt          DateTime            @default(now())
  groups             Group[]
  users              User[]
  trucks             Truck[]
  trips              Trip[]
  logo            String?
  logoPublicId  String?
  accountingEmail String?
  hrEmail         String?
  directorEmail   String?
  inviteToken  String?   @unique
  inviteExpiry DateTime?
  isActive     Boolean   @default(true)
  announcements      Announcement[]
  announcementDrafts AnnouncementDraft[]
  advanceRequests AdvanceRequest[]
  alarms          Alarm[]
}

model TruckNote {
  id        String   @id @default(uuid())
  truckId   String
  userId    String
  content   String
  createdAt DateTime @default(now())

  truck Truck @relation(fields: [truckId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

model User {
  id                 String              @id @default(uuid())
  firstName          String
  lastName           String?
  email              String?             @unique
  phone              String?             @unique
  password           String?
  avatar String?
  avatarPublicId String?
  role               Role
  language           Language            @default(EN)
  timezone           String?             // IANA tz, e.g. "Europe/Warsaw"
  /// Self-set presence status. Combined with socket presence on read:
  /// no active socket -> displayed as OFFLINE regardless. ONLINE while a
  /// socket is up. BUSY / SLEEP both suppress push notifications.
  status             UserStatus          @default(ONLINE)
  /// When non-null, BUSY/SLEEP auto-expires at this instant — the next
  /// read resolves the user back to ONLINE.
  statusUntil        DateTime?
  isActive           Boolean             @default(true)
  companyId          String
  createdAt          DateTime            @default(now())
  managerId    String?
  teamleadId   String?
  inviteToken    String?
  inviteExpiry   DateTime?
  sentMessages     DirectMessage[] @relation("SentMessages")
  receivedMessages DirectMessage[] @relation("ReceivedMessages")
  groupMessages GroupMessage[]

  manager    User?  @relation("DriverManager", fields: [managerId], references: [id])
  teamlead   User?  @relation("ManagerTeamlead", fields: [teamleadId], references: [id])
  drivers     User[] @relation("DriverManager")
  managers    User[] @relation("ManagerTeamlead")
  groupsCreated      Group[]             @relation("GroupCreator")
  groupManagers      GroupManager[]
  truckNotes         TruckNote[]
  company            Company             @relation(fields: [companyId], references: [id])
  tripsAsDriver      Trip[]              @relation("DriverTrips")
  tripsAsManager     Trip[]              @relation("ManagerTrips")
  messages           Message[]
  comments           TripComment[]
  alarmsCreated      Alarm[]             @relation("AlarmCreator")
  alarmsTargeted     Alarm[]             @relation("AlarmTarget")
  uploadedDocuments  TripDocument[]
  dmDocsUploaded     DirectMessageDocument[] @relation("DMDocsUploader")
  dmDocsReceived     DirectMessageDocument[] @relation("DMDocsOtherUser")
  groupDocsUploaded  GroupMessageDocument[]  @relation("GroupDocsUploader")
  announcementReads  AnnouncementRead[]
  announcements      Announcement[]
  announcementDrafts AnnouncementDraft[]
  currentTruck       Truck?              @relation("CurrentDriver")
  assignedTrucks     Truck[]             @relation("TruckManager")
  advanceRequests AdvanceRequest[] @relation("DriverAdvanceRequests")
  otpCodes           OtpCode[]
  ratingsReceived         DriverRating[]  @relation("DriverRatings")
  ratingsGiven            DriverRating[]  @relation("GivenRatings")
  managerRatingsReceived  ManagerRating[] @relation("ManagerRatings")
  managerRatingsGiven     ManagerRating[] @relation("GivenManagerRatings")
  sessionsAsDriver     TripChatSession[] @relation("SessionDriver")
  sessionsAsManager    TripChatSession[] @relation("SessionManager")
  pushTokens         PushToken[]
  passwordResetTokens PasswordResetToken[]
  hiddenConversations HiddenConversation[] @relation("HiddenConversations")
  groupMessageReads  GroupMessageRead[] @relation("GroupMessageReads")
  messageReactions   MessageReaction[]  @relation("MessageReactions")
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String?  // "ios" | "android" | "web"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Per-user "delete for me" for a DM conversation. Filter in getConversations
/// hides the peer whose last message is at or before hiddenAt; a newer message
/// resurrects the conversation naturally (matches Telegram delete-chat UX).
model HiddenConversation {
  id       String   @id @default(uuid())
  userId   String
  peerId   String
  hiddenAt DateTime @default(now())

  user User @relation("HiddenConversations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, peerId])
  @@index([userId])
}

enum UserStatus {
  ONLINE
  BUSY
  AWAY
  SLEEP
  VACATION
}

enum Role {
  ADMIN
  TEAMLEAD
  MANAGER
  DRIVER
}

enum Language {
  UK
  EN
  PL
  LT
  UZ
  KZ
  HI
  RU
}

model Truck {
  id              String      @id @default(uuid())
  plate           String
  status          TruckStatus @default(AVAILABLE)
  isActive        Boolean     @default(true)
  truckNotes      TruckNote[]
  companyId       String
  currentDriverId String?     @unique
  managerId       String?
  createdAt       DateTime    @default(now())

  groups        GroupTruck[]
  company       Company      @relation(fields: [companyId], references: [id])
  currentDriver User?        @relation("CurrentDriver", fields: [currentDriverId], references: [id])
  manager       User?        @relation("TruckManager", fields: [managerId], references: [id])
  trips         Trip[]
}

enum TruckStatus {
  AVAILABLE
  ON_TRIP
  REPAIR
}

model Trip {
  id           String     @id @default(uuid())
  title        String
  status       TripStatus @default(ASSIGNED)
  managerId    String
  driverId     String
  truckId      String
  companyId    String
  notes        String?
  orderNumber  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  chatResetAt  DateTime?  // встановлюється при зміні водія — чат "починається заново"

  manager    User           @relation("ManagerTrips", fields: [managerId], references: [id])
  driver     User           @relation("DriverTrips", fields: [driverId], references: [id])
  truck      Truck          @relation(fields: [truckId], references: [id])
  company    Company        @relation(fields: [companyId], references: [id])
  stops      TripStop[]
  documents  TripDocument[]
  messages   Message[]
  comments   TripComment[]
  alarms     Alarm[]
  chatSessions TripChatSession[]
}

model TripChatSession {
  id         String            @id @default(uuid())
  tripId     String
  driverId   String?           // null only for LEGACY_RESET sessions
  managerId  String?           // null only for LEGACY_RESET sessions
  startedAt  DateTime          @default(now())
  endedAt    DateTime?
  endReason  SessionEndReason?

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driver   User?     @relation("SessionDriver", fields: [driverId], references: [id])
  manager  User?     @relation("SessionManager", fields: [managerId], references: [id])
  messages Message[]

  @@index([tripId, endedAt])
  @@index([driverId])
  @@index([managerId])
}

enum SessionEndReason {
  DRIVER_CHANGED
  MANAGER_CHANGED
  TRIP_COMPLETED
  LEGACY_RESET
}

model TripStop {
  id      String   @id @default(uuid())
  tripId  String
  type    StopType
  order   Int      @default(0)
  address String?  // full address: company, street, postcode, city
  ref     String?
  coords  String?  // "lat,lng" format

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

enum StopType {
  LOADING
  UNLOADING
}

enum TripStatus {
  ASSIGNED
  ACCEPTED
  ON_WAY
  ON_SITE
  LOADED
  DELIVERED
}

enum FileDocType {
  PHOTO
  DOCUMENT
}

model TripDocument {
  id                String      @id @default(uuid())
  tripId            String
  fileUrl           String
  fileName          String
  uploadedBy        String
  fileType          FileDocType @default(DOCUMENT)
  isRead            Boolean     @default(false)
  createdAt         DateTime    @default(now())
  deletedAt         DateTime?
  publicId          String?
  caption           String?
  replyToMessageId  String?
  replyToDocumentId String?
  trip     Trip @relation(fields: [tripId], references: [id])
  uploader User @relation(fields: [uploadedBy], references: [id])

  replyTo         Message?      @relation("TripMsgDocReplies", fields: [replyToMessageId], references: [id])
  replyToDocument TripDocument? @relation("TripDocToDocReplies", fields: [replyToDocumentId], references: [id])

  msgRepliedFrom Message[]       @relation("TripMsgToDocReplies")
  docRepliedFrom TripDocument[]  @relation("TripDocToDocReplies")

  @@index([tripId, isRead])
}

model DirectMessageDocument {
  id                String      @id @default(uuid())
  uploadedBy        String      // хто завантажив
  otherUserId       String      // інший учасник conversation
  fileUrl           String
  fileName          String
  fileType          FileDocType @default(DOCUMENT)
  isRead            Boolean     @default(false)
  createdAt         DateTime    @default(now())
  deletedAt         DateTime?
  publicId          String?
  caption           String?
  replyToMessageId  String?
  replyToDocumentId String?

  uploader  User @relation("DMDocsUploader",  fields: [uploadedBy],  references: [id])
  otherUser User @relation("DMDocsOtherUser", fields: [otherUserId], references: [id])

  replyTo         DirectMessage?         @relation("DmMsgDocReplies", fields: [replyToMessageId], references: [id])
  replyToDocument DirectMessageDocument? @relation("DmDocToDocReplies", fields: [replyToDocumentId], references: [id])

  msgRepliedFrom DirectMessage[]         @relation("DmMsgToDocReplies")
  docRepliedFrom DirectMessageDocument[] @relation("DmDocToDocReplies")

  @@index([uploadedBy, otherUserId])
  @@index([otherUserId, uploadedBy])
}

model GroupMessageDocument {
  id                String      @id @default(uuid())
  groupId           String
  uploadedBy        String
  fileUrl           String
  fileName          String
  fileType          FileDocType @default(DOCUMENT)
  isRead            Boolean     @default(false)
  createdAt         DateTime    @default(now())
  deletedAt         DateTime?
  publicId          String?
  caption           String?
  replyToMessageId  String?
  replyToDocumentId String?

  group    Group @relation(fields: [groupId],   references: [id])
  uploader User  @relation("GroupDocsUploader", fields: [uploadedBy], references: [id])

  replyTo         GroupMessage?         @relation("GroupMsgDocReplies", fields: [replyToMessageId], references: [id])
  replyToDocument GroupMessageDocument? @relation("GroupDocToDocReplies", fields: [replyToDocumentId], references: [id])

  msgRepliedFrom GroupMessage[]         @relation("GroupMsgToDocReplies")
  docRepliedFrom GroupMessageDocument[] @relation("GroupDocToDocReplies")

  @@index([groupId])
  @@index([uploadedBy])
}

model DirectMessage {
  id                 String    @id @default(uuid())
  senderId           String
  receiverId         String
  content            String
  isRead             Boolean   @default(false)
  createdAt          DateTime  @default(now())
  deletedAt          DateTime?
  editedAt           DateTime?
  replyToId          String?
  replyToDocumentId  String?

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])

  replyTo         DirectMessage?         @relation("DmReplies", fields: [replyToId], references: [id])
  replies         DirectMessage[]        @relation("DmReplies")
  replyToDocument DirectMessageDocument? @relation("DmMsgToDocReplies", fields: [replyToDocumentId], references: [id])

  docReplies DirectMessageDocument[] @relation("DmMsgDocReplies")

  // getMessages scans a 1-to-1 conversation in chronological order. These
  // compound indexes let the planner satisfy both the OR-of-pairs filter
  // AND the createdAt sort without a separate sort step.
  @@index([senderId, receiverId, createdAt])
  @@index([receiverId, senderId, createdAt])
  // Unread counters per conversation use (senderId, receiverId, isRead).
  @@index([receiverId, isRead])
}

model Message {
  id                String    @id @default(uuid())
  tripId            String
  sessionId         String
  senderId          String
  content           String
  translatedContent String?
  isRead            Boolean   @default(false)
  isSystem          Boolean   @default(false) // system event (driver/manager changed) — rendered specially
  createdAt         DateTime  @default(now())
  deletedAt         DateTime?
  editedAt          DateTime?
  replyToId         String?
  replyToDocumentId String?

  trip    Trip            @relation(fields: [tripId], references: [id])
  session TripChatSession @relation(fields: [sessionId], references: [id])
  sender  User            @relation(fields: [senderId], references: [id])

  replyTo         Message?      @relation("TripMsgReplies", fields: [replyToId], references: [id])
  replies         Message[]     @relation("TripMsgReplies")
  replyToDocument TripDocument? @relation("TripMsgToDocReplies", fields: [replyToDocumentId], references: [id])

  docReplies TripDocument[] @relation("TripMsgDocReplies")

  @@index([tripId, isRead])
  @@index([sessionId])
  // findByTrip orders by createdAt — composite index serves the WHERE
  // + ORDER BY in a single index scan instead of "sort 500 rows".
  @@index([sessionId, createdAt])
}

// Note: TripDocument also gets `isRead` so the trip chat shows ✓/✓✓ on docs
// the same way it does on messages. Updated below — see model TripDocument.

model TripComment {
  id        String   @id @default(uuid())
  tripId    String
  driverId  String
  content   String
  createdAt DateTime @default(now())

  trip   Trip @relation(fields: [tripId], references: [id])
  driver User @relation(fields: [driverId], references: [id])
}

model Alarm {
  id           String           @id @default(uuid())
  companyId    String
  createdById  String           // who scheduled the alarm
  targetUserId String           // whom to wake — self (== createdById) or another user
  tripId       String?          // optional: alarm linked to a specific trip
  title        String           // тема — short subject shown as push title
  note         String?          // optional details / body
  time         DateTime         // when to fire next
  recurrence   AlarmRecurrence  @default(NONE)
  isSent       Boolean          @default(false) // for one-shot alarms; recurring alarms reset on each fire
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  creator User    @relation("AlarmCreator", fields: [createdById], references: [id])
  target  User    @relation("AlarmTarget", fields: [targetUserId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])

  @@index([targetUserId, isSent, time])
  @@index([companyId])
  @@index([tripId])
}

enum AlarmRecurrence {
  NONE
  DAILY
  WEEKLY
}

model Announcement {
  id         String             @id @default(uuid())
  companyId  String
  createdBy  String
  title      String
  content    String
  target     AnnouncementTarget
  isTemplate Boolean            @default(false)
  createdAt  DateTime           @default(now())
  groupId    String?
  updatedAt DateTime @updatedAt

  group   Group?             @relation(fields: [groupId], references: [id])
  company Company            @relation(fields: [companyId], references: [id])
  creator User               @relation(fields: [createdBy], references: [id])
  reads   AnnouncementRead[]
}

enum AnnouncementTarget {
  ALL_DRIVERS
  ALL_MANAGERS
  ALL
}

model AnnouncementRead {
  id             String   @id @default(uuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
}

model AnnouncementDraft {
  id         String             @id @default(uuid())
  companyId  String
  createdBy  String
  title      String
  content    String
  target     AnnouncementTarget
  isTemplate Boolean            @default(false)
  createdAt  DateTime           @default(now())
  groupId    String?

  company Company @relation(fields: [companyId], references: [id])
  creator User    @relation(fields: [createdBy], references: [id])
  Group   Group?  @relation(fields: [groupId], references: [id])
}

model OtpCode {
  id        String    @id @default(uuid())
  phone     String
  code      String
  userId    String
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([phone, createdAt])
}

enum GroupType {
  TRUCKS
  MANAGERS
}

model Group {
  id              String    @id @default(uuid())
  name            String
  avatar          String?
  avatarPublicId  String?
  type            GroupType
  companyId       String
  createdBy       String
  createdAt       DateTime  @default(now())
  /// Soft-delete marker. When set, the group is invisible to every member
  /// but its rows (messages, docs, members) stay put so foreign keys don't
  /// break. Only the creator can flip this.
  deletedAt       DateTime?
  messages GroupMessage[]
  documents GroupMessageDocument[]
  company            Company             @relation(fields: [companyId], references: [id])
  creator            User                @relation("GroupCreator", fields: [createdBy], references: [id])
  trucks             GroupTruck[]
  managers           GroupManager[]
  announcements      Announcement[]
  announcementsDraft AnnouncementDraft[]
}
model GroupMessage {
  id                String    @id @default(uuid())
  groupId           String
  senderId          String
  content           String
  /// System-authored notices ("added X", "removed X"). The frontend renders
  /// these as small, centred, muted text — no bubble, no avatar, no reply.
  isSystem          Boolean   @default(false)
  createdAt         DateTime  @default(now())
  deletedAt         DateTime?
  editedAt          DateTime?
  replyToId         String?
  replyToDocumentId String?

  group  Group              @relation(fields: [groupId], references: [id])
  sender User               @relation(fields: [senderId], references: [id])
  reads  GroupMessageRead[]

  replyTo         GroupMessage?         @relation("GroupMsgReplies", fields: [replyToId], references: [id])
  replies         GroupMessage[]        @relation("GroupMsgReplies")
  replyToDocument GroupMessageDocument? @relation("GroupMsgToDocReplies", fields: [replyToDocumentId], references: [id])

  docReplies GroupMessageDocument[] @relation("GroupMsgDocReplies")

  // Group history is fetched WHERE groupId=… ORDER BY createdAt.
  @@index([groupId, createdAt])
}

// Generic reaction table — one row per (message, user). One reaction max
// per user per message; pressing another emoji replaces it (toggle).
// targetType discriminates which message table targetId points into:
//   "TRIP"  → Message.id
//   "DM"    → DirectMessage.id
//   "GROUP" → GroupMessage.id
model MessageReaction {
  id         String   @id @default(uuid())
  targetType String // "TRIP" | "DM" | "GROUP"
  targetId   String
  userId     String
  emoji      String // "👍" | "😮" | "😢"
  createdAt  DateTime @default(now())

  user User @relation("MessageReactions", fields: [userId], references: [id])

  @@unique([targetType, targetId, userId])
  @@index([targetType, targetId])
  @@index([userId])
}

model GroupMessageRead {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User         @relation("GroupMessageReads", fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([userId])
  @@index([messageId])
}

model GroupTruck {
  id      String @id @default(uuid())
  groupId String
  truckId String

  group Group @relation(fields: [groupId], references: [id])
  truck Truck @relation(fields: [truckId], references: [id])
}

model GroupManager {
  id        String @id @default(uuid())
  groupId   String
  managerId String

  group   Group @relation(fields: [groupId], references: [id])
  manager User  @relation(fields: [managerId], references: [id])
}
model DriverRating {
  id        String   @id @default(uuid())
  driverId  String
  ratedById String
  score     Int
  comment   String?
  anonymous Boolean  @default(false)
  createdAt DateTime @default(now())

  driver  User @relation("DriverRatings", fields: [driverId], references: [id])
  ratedBy User @relation("GivenRatings", fields: [ratedById], references: [id])

  @@unique([driverId, ratedById])
}

model ManagerRating {
  id        String   @id @default(uuid())
  managerId String
  ratedById String
  score     Int
  comment   String?
  anonymous Boolean  @default(false)
  createdAt DateTime @default(now())

  manager User @relation("ManagerRatings", fields: [managerId], references: [id])
  ratedBy User @relation("GivenManagerRatings", fields: [ratedById], references: [id])

  @@unique([managerId, ratedById])
}

model AdvanceRequest {
  id        String        @id @default(uuid())
  driverId  String
  companyId String
  amount    Float
  reason    String
  createdAt DateTime      @default(now())

  driver  User    @relation("DriverAdvanceRequests", fields: [driverId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
}

